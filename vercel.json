{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/favicon\\.(ico|png|jpg|jpeg)",
      "dest": "/api/favicon",
      "continue": false
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "continue": false
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/favicon.js": {
      "memory": 128,
      "maxDuration": 10
    }
  }
}
